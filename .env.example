# Copia este archivo como .env.local y rellena con los valores de tu proyecto Supabase
# (Dashboard → Project Settings → API)

VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-publica

# Estas dos NO van en el frontend (van como secrets de las Edge Functions, Fase 3):
# TELEGRAM_BOT_TOKEN=...
# RESEND_API_KEY=...
